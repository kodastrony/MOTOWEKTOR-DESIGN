{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "next-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "-p", "5000"],
      "port": 5000
    },
    {
      "name": "next-start",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 3000
    },
    {
      "name": "docker-dev",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "dev", "--build"],
      "port": 3001
    },
    {
      "name": "docker-app",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "app", "--build"],
      "port": 3000
    }
  ]
}
